# Copy to keystore.properties (gitignored) and fill in values.
# Paths can be relative to the project root or absolute.
#
# Create a keystore once, for example:
#   keytool -genkeypair -v -keystore truffle-release.jks -keyalg RSA \
#     -keysize 2048 -validity 10000 -alias truffle
#
storeFile=truffle-release.jks
storePassword=change-me
keyAlias=truffle
keyPassword=change-me
